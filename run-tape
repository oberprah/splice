#!/usr/bin/env bash
# Helper script to run tape-runner without explicit build step
# Usage: ./run-tape <tape-file>
#        ./run-tape --help

set -e

# Get the directory where this script is located (project root)
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Ensure tmux is installed (needed for all tape tests)
# freeze is installed on-demand only when Snapshot commands are used
if ! command -v tmux &> /dev/null; then
  "${SCRIPT_DIR}/scripts/env-setup/install-tmux.sh"
  echo ""
fi

exec go run ./test/agent/tape-runner "$@"
