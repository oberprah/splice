#!/bin/sh

# Splice pre-commit hook
# Runs the same checks as CI pipeline to catch issues early

set -e

echo "Running pre-commit checks..."

cd "$(dirname "$0")/.."

# Source mise if available
if [ -f "$HOME/.local/share/mise.sh" ]; then
    . "$HOME/.local/share/mise.sh"
fi

# 1. Format
printf "→ Format... "
if cargo fmt -- --check > /tmp/splice-fmt.log 2>&1; then
    echo "✓"
else
    echo "✗"
    cat /tmp/splice-fmt.log
    exit 1
fi

# 2. Lint
printf "→ Lint... "
if cargo clippy > /tmp/splice-clippy.log 2>&1; then
    echo "✓"
else
    echo "✗"
    cat /tmp/splice-clippy.log
    exit 1
fi

# 3. Tests
printf "→ Tests... "
if cargo test > /tmp/splice-test.log 2>&1; then
    echo "✓"
else
    echo "✗"
    cat /tmp/splice-test.log
    exit 1
fi

echo "All checks passed!"
